# ============================================================
# 密钥/环境变量模板（可提交，仅键名无真值）
# ------------------------------------------------------------
# 使用方法：
#   1. 复制本文件为 .env       ->  cp .env.example .env
#   2. 在 .env 中填入真实值
#   3. .env 已被 .gitignore 忽略，绝不会提交
# 代码通过 python-dotenv / os.environ 读取，config.yaml 不放密钥。
# ============================================================

# 后期若接入外部大模型/API 做失效归因报告生成时使用（基础版可留空）
LLM_API_KEY=
LLM_BASE_URL=

# 若将来部署为服务，可在此放服务端口/鉴权 token（基础版不需要）
SERVICE_TOKEN=
